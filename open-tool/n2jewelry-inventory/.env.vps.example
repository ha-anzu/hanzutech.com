# App
NODE_ENV=production
PORT=3020
APP_BASE_URL=https://inventory.n2jewels.com

# Postgres
POSTGRES_DB=n2inventory
POSTGRES_USER=n2inventory
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgres://n2inventory:change-this-strong-password@db:5432/n2inventory

# S3-compatible object storage
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=n2jewelry-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
